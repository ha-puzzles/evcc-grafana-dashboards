# =============================================================================
# Grafana Dashboard Exporter Configuration
# =============================================================================
# Copy this file to .env and edit values as needed.
# The .env file will be loaded automatically by export-dashboards.sh

# Grafana server URL
GRAFANA_URL="http://localhost:3000"

# Grafana authentication
GRAFANA_USER="admin"
GRAFANA_PASSWORD="admin"

# Grafana namespace (for V2 API)
GRAFANA_NAMESPACE="default"

# Output directory for exported dashboards (absolute or relative to script)
OUTPUT_DIR="./exported-dashboards"

# Dashboard mappings: UID -> filename
declare -A DASHBOARDS=(
    ["ad5ks8d"]="today-mobile.json"
    ["adddvtj"]="today-details.json"
    ["adsmz7v"]="today.json"
    ["adz6thx"]="month.json"
)

# Additional curl options (optional)
# CURL_OPTS="-s --fail --show-error"